# ===== Ghost site (本地写作后台) =====
# 保持本地地址即可;Ghost 只在本机当 CMS,不直接对外。
GHOST_URL=http://localhost:2368

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=ghost
MYSQL_USER=ghost
MYSQL_PASSWORD=change-me-ghost

# ===== GitHub Pages 发布 =====
# 静态站最终对外的【完整地址】。generate.sh 会自动拆成 origin + 子路径:
#   项目站仓库(任意仓库名,带子路径):https://shepherdloveyou.github.io/ada-blog
#   用户站仓库(仓库名=<用户名>.github.io):https://shepherdloveyou.github.io
#   自定义域名:                        https://blog.example.com
# 带子路径时会自动加 --subDir,资源转相对路径,子路径下可正常加载。
PAGES_URL=https://shepherdloveyou.github.io/ada-blog

# 仅自定义域名需要:发布时写入 gh-pages 的 CNAME(留空则不写)。
# PAGES_CNAME=blog.example.com

# ===== 邮件 / 会员 / newsletter(预留,静态站不支持;留待将来上服务器再用)=====
# MAIL_USER=postmaster@mg.example.com
# MAIL_PASS=your-mailgun-smtp-password
